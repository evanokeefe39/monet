# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: web search
# TAVILY_API_KEY=

# Postgres — must match the credentials baked into .monet/docker-compose.yml.
DATABASE_URL=postgresql://local:local_secret@localhost:5432/local

# Langfuse — only needed with: docker compose --profile tracing up
# Create keys at http://localhost:3000 after first boot
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
