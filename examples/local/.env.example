# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: web search
# TAVILY_API_KEY=

# Postgres — `monet dev` auto-provisions it via .monet/docker-compose.yml.
# Defaults (user/db/password = "local" / "local_secret" / "local") work
# out of the box; override here only if you need custom credentials.
# POSTGRES_USER=local
# POSTGRES_PASSWORD=local_secret
# POSTGRES_DB=local

# Langfuse — only needed with: docker compose --profile tracing up
# Create keys at http://localhost:3000 after first boot
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
