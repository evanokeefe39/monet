# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: web search
# TAVILY_API_KEY=

# Postgres — checkpointing (started by docker compose)
POSTGRES_URL=postgresql://monet:monet@localhost:5432/monet

# Langfuse — only needed with: docker compose --profile tracing up
# Create keys at http://localhost:3000 after first boot
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000
