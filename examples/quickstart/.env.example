# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: web search
# TAVILY_API_KEY=

# Optional: tracing (Langfuse)
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# Optional: local JSONL span dump for debugging.
# Writes one span per line, appended. Runs in addition to any OTLP
# backend above — uncomment to enable.
# MONET_TRACE_FILE=.monet/traces.jsonl

# Optional: catalogue storage (default: .catalogue/)
# MONET_CATALOGUE_DIR=
