# Copy to .env and fill in your API keys.
# See docs/reference/models.md for the full model catalog and provider URLs.

# NVIDIA NIM — default provider for zeroclaw and pi.
# https://build.nvidia.com → API Key
NVIDIA_NIM_API_KEY=nvapi-...

# Groq — fallback for hermes and openclaw if NIM rate-limits.
# https://console.groq.com
GROQ_API_KEY=gsk_...

# Adapter ports (documentation reference — not read by monet).
# If you change these, update the transport URLs in agents.toml to match.
# ZEROCLAW_ADAPTER_PORT=8091
# PI_ADAPTER_PORT=8092
# HERMES_ADAPTER_PORT=8093
# OPENCLAW_ADAPTER_PORT=8094

# monet server (set before starting the worker)
MONET_SERVER_URL=http://localhost:2026

# Postgres / Redis (monet dev infrastructure)
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw_secret
POSTGRES_DB=openclaw
