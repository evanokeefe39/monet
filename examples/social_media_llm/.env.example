# Copy to .env and fill in your keys. python-dotenv loads this on startup.

# Required — defaults for planner / researcher / writer / publisher
GEMINI_API_KEY=

# Required — default for qa
GROQ_API_KEY=

# Optional — preferred web search for researcher/deep
EXA_API_KEY=

# Optional — alternative web search for researcher/deep
TAVILY_API_KEY=

# Optional — override the catalogue location. If unset, both the CLI
# and the langgraph dev server default to <example_dir>/.catalogue,
# anchored to the location of app.py / server_graphs.py so both
# processes resolve to the same on-disk directory regardless of which
# working directory they were started from. If you set this explicitly,
# use an ABSOLUTE path — a relative value will resolve against each
# process's cwd and the two sides will desync.
# MONET_CATALOGUE_DIR=/abs/path/to/catalogue

# Optional tracing — pick one backend. All three shortcuts fill in the
# OTLP endpoint and auth header for you. Explicit OTEL_EXPORTER_OTLP_*
# vars override any shortcut below.
OTEL_SERVICE_NAME=monet-social-media-llm

# Langfuse local stack (docker-compose.dev.yml at repo root):
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=http://localhost:3000

# Or LangSmith:
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=monet-social-media-llm

# Or Honeycomb:
# HONEYCOMB_API_KEY=...
# HONEYCOMB_DATASET=monet-social-media-llm

# Or explicit OTLP (overrides all shortcuts above):
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=

# Optional model overrides — any init_chat_model() string works
# MONET_PLANNER_MODEL=google_genai:gemini-2.5-flash
# MONET_RESEARCHER_MODEL=google_genai:gemini-2.5-flash
# MONET_WRITER_MODEL=google_genai:gemini-2.5-flash
# MONET_QA_MODEL=groq:llama-3.3-70b-versatile
# MONET_PUBLISHER_MODEL=google_genai:gemini-2.5-flash
