# ── LLM Providers (required: at least one) ──
GEMINI_API_KEY=
GROQ_API_KEY=
# TAVILY_API_KEY=          # optional: enables web search

# ── Postgres (checkpointing) ──
# Railway: add the Postgres plugin, uses DATABASE_URL automatically
# Neon:    https://console.neon.tech -> create project -> copy connection string
# Other:   any Postgres 14+ instance
POSTGRES_URL=postgresql://user:pass@host:5432/dbname

# ── Redis (task queue) ──
# Railway: add the Redis plugin, uses REDIS_URL automatically
# Upstash: https://console.upstash.com -> create database -> copy REST URL
# Other:   any Redis 7+ instance
# REDIS_URL=redis://localhost:6379

# ── Tracing (optional) ──
# Langfuse Cloud: https://cloud.langfuse.com -> create project -> API keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ── Monet server auth ──
MONET_API_KEY=change-me-to-a-random-secret
