# LLM API keys
GEMINI_API_KEY=...
GROQ_API_KEY=...
# TAVILY_API_KEY=...  # optional: enables web search in researcher/deep

# Postgres — used by LangGraph for checkpointing
POSTGRES_URL=postgresql://monet:monet@localhost:5432/monet

# Langfuse — create an API key pair at http://localhost:3000 after first boot
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Catalogue (filesystem by default)
MONET_CATALOGUE_DIR=.catalogue
