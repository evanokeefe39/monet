# ── LLM Providers (required: at least one) ──
GEMINI_API_KEY=
GROQ_API_KEY=
# TAVILY_API_KEY=          # optional: enables web search

# ── Monet server auth (shared by server + worker + clients) ──
MONET_API_KEY=change-me-to-a-random-secret

# ── Postgres (checkpointing, server-side only) ──
# Railway: add the Postgres plugin, uses DATABASE_URL automatically
# Neon:    https://console.neon.tech -> create project -> copy connection string
# Other:   any Postgres 14+ instance
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Redis (task queue — required for distributed workers) ──
# Railway: add the Redis plugin, uses REDIS_URI automatically
# Upstash: https://console.upstash.com -> create database (use the TCP
#          connection string, not the REST URL — the queue needs
#          blocking XREADGROUP and Pub/Sub subscribe)
# Other:   any Redis 7+ instance
REDIS_URI=redis://localhost:6379
MONET_QUEUE_BACKEND=redis

# ── Worker-side only: point at the server's public URL ──
# Railway: https://<your-server-service>.up.railway.app
# Local compose: http://monet:2026 (the service name)
MONET_SERVER_URL=http://monet:2026

# ── Tracing (optional) ──
# Langfuse Cloud: https://cloud.langfuse.com -> create project -> API keys
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
