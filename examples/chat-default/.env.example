# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# PostgreSQL — provisioned automatically by `monet dev`.
# These defaults match what the generated docker-compose produces.
POSTGRES_USER=chat_default
POSTGRES_PASSWORD=chat_default_secret
POSTGRES_DB=chat_default
