# Required: at least one LLM provider
GEMINI_API_KEY=
GROQ_API_KEY=

# Optional: tracing
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=http://localhost:3000

# PostgreSQL — provisioned automatically by `monet dev`.
# Must match the credentials baked into .monet/docker-compose.yml.
DATABASE_URL=postgresql://chat_default:chat_default_secret@localhost:5432/chat_default
