# ── Monet server auth (shared by server + workers + clients) ──
MONET_API_KEY=change-me-to-a-random-secret

# ── Postgres (checkpointing, server-side only) ──
# Compose:  postgresql://monet:monet@postgres:5432/monet  (set automatically)
# Railway:  from the Postgres plugin
POSTGRES_URL=postgresql://monet:monet@postgres:5432/monet

# ── Redis (task queue — required for distributed workers) ──
# Compose:  redis://redis:6379  (set automatically)
# Railway:  from the Redis plugin
REDIS_URI=redis://redis:6379
MONET_QUEUE_BACKEND=redis

# ── Worker-side only: point at the server's public URL ──
# Compose:  http://monet:2026 (the service name)
# Railway:  https://<your-server-service>.up.railway.app
MONET_SERVER_URL=http://monet:2026
