# Postgres (used by langgraph-checkpoint-postgres)
POSTGRES_URL=postgresql://monet:monet@localhost:5432/monet

# OTel — point at any OTLP-compatible backend
OTEL_SERVICE_NAME=monet

# Option A: Langfuse convenience — set these and monet auto-derives the
# OTLP endpoint and Basic auth header for the local docker-compose stack.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

# Option B: LangSmith shortcut — sets endpoint + x-api-key header automatically.
# LANGSMITH_API_KEY=lsv2_...
# LANGSMITH_PROJECT=monet  # optional

# Option C: Honeycomb shortcut — sets endpoint + x-honeycomb-team header automatically.
# HONEYCOMB_API_KEY=...
# HONEYCOMB_DATASET=monet  # optional

# Option D: explicit OTLP (any backend — overrides all shortcut vars above)
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.example.com/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer <token>

# Artifact store
# IMPORTANT: SQLite URL must use the sqlite+aiosqlite:// scheme,
# not sqlite:///, otherwise SQLAlchemy will use the synchronous driver
# and raise on async operations.
MONET_ARTIFACTS_DIR=.artifacts
MONET_ARTIFACTS_DB_URL=sqlite+aiosqlite:///.artifacts/index.db
